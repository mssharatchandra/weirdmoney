# WYRD runtime config — copy the real values into ~/.hermes/.env
# (Hermes loads ~/.hermes/.env for tool subprocesses.)

# Vercel data gateway. Runs outside the visitor's ISP and uses public read-only data.
WYRD_GATEWAY_URL=https://wyrd-money.vercel.app/api/weird

# Convex HTTP domain (note: .convex.site, NOT .convex.cloud). See CONVEX_SETUP.md.
WYRD_CONVEX_URL=https://hip-squirrel-523.convex.site

# Telegram bot token from @BotFather — used to broadcast drops to subscribers.
TELEGRAM_BOT_TOKEN=

# Absolute path to the wyrd skill dir, so skill scripts resolve bin/ reliably.
WYRD_SKILL_DIR=/Users/sharat/Downloads/CURIOUS/weirdmoney/skills/wyrd

# Landing page URL (used in reply #1).
WYRD_LANDING_URL=https://wyrd-money.vercel.app

# Optional live-news enrichment for the hunter. Obtain from Linkup.
LINKUP_API_KEY=
